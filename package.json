{
  "name": "stepsnap",
  "version": "0.2.1",
  "description": "Annotated screenshot walkthrough builder & viewer — open-source alternative to Scribe",
  "type": "module",
  "main": "./dist/stepsnap.umd.cjs",
  "module": "./dist/stepsnap.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/stepsnap.js",
      "require": "./dist/stepsnap.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.lib.json",
    "build:embed": "cross-env BUILD_MODE=embed vite build",
    "build:wc": "vite build --config vite.wc.config.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "keywords": [
    "walkthrough",
    "tutorial",
    "screenshot",
    "annotation",
    "react",
    "scribe"
  ],
  "license": "AGPL-3.0-only",
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1"
  }
}
